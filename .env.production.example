# Production environment (used by docker-compose.prod.yml)
DATABASE_URL="postgresql://DB_USER:DB_PASSWORD@DB_HOST:5432/DB_NAME?schema=public"
JWT_SECRET="replace-with-very-strong-random-secret"
INITIAL_BALANCE="600"
PORT="3000"
APP_HOST_PORT="3101"
NODE_ENV="production"

# Optional bootstrap admin on first run (only if no active admin exists)
DEFAULT_ADMIN_USERNAME="admin"
DEFAULT_ADMIN_PASSWORD="ChangeMe_Immediately"
DEFAULT_ADMIN_NAME="System Admin"

# Optional default password for imported/reset facility users
DEFAULT_FACILITY_PASSWORD="123456"
